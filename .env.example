# Path to a single PDF file OR a folder containing *.pdf
DOCS_PATH=docs

# Ollama model name (must be pulled/available in Ollama)
LLM_MODEL=llama3

# Ollama server URL (optional)
OLLAMA_URL=http://localhost:11434

# HuggingFace embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval
TOP_K=4
RETRIEVAL_TYPE=similarity

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Storage (optional)
DB_FAISS_PATH=vectorstore/db_faiss
MANIFEST_FILE=vectorstore/index_manifest.json
LOG_DIR=logs
SESSION_FILE=logs/session_history.json
